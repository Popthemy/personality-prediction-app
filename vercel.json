{
  "name": "big-five-personality-prediction",
  "version": 1,
  "buildCommand": "docker build -t personality-app .",
  "devCommand": "python manage.py runserver 0.0.0.0:8000",
  "env": {
    "DJANGO_SETTINGS_MODULE": "backend.config.settings.prod",
    "SECRET_KEY": "@vercel/system-env-secret",
    "DEBUG": "False",
    "ALLOWED_HOSTS": "localhost,127.0.0.1,.vercel.app"
  },
  "envPrefix": "VERCEL_",
  "framework": "django",
  "regions": ["iad1"],
  "runtime": "docker"
}
